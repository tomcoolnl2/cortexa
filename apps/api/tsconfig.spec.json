{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "module": "commonjs",
        "types": ["vitest/globals", "node"],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "target": "es2021",
        "moduleResolution": "node"
    },
    "include": [
        "vite.config.mts",
        "src/**/*.test.ts",
        "src/**/*.spec.ts",
        "tests/**/*.ts"
    ]
}
