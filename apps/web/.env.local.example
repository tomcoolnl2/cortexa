# Google SSO credentials (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# NextAuth session encryption key (generate a random string)
NEXTAUTH_SECRET="replace-with-random-secret"

# Must match between web and API for JWT validation
API_JWT_SECRET="replace-with-shared-jwt-secret"

# Your Google account email — the only user who can sign in initially
ADMIN_EMAIL="you@gmail.com"
