{
    "name": "cortexa",
    "version": "1.0.0",
    "main": "index.js",
    "directories": {
        "doc": "docs"
    },
    "scripts": {
        "serve:api": "dotenv -- nx serve api",
        "serve:web": "dotenv -- nx dev web",
        "serve:dev": "dotenv -- nx run-many -t serve dev --projects=api,web",
        "storybook": "nx storybook ui",
        "test": "nx run-many -t test --exclude=cortexa",
        "test:domain": "nx test domain",
        "lint": "nx run-many -t lint --exclude=cortexa",
        "build": "nx run-many -t build",
        "build:api": "nx build api",
        "build:web": "nx build web",
        "graph": "nx graph",
        "db:up": "docker compose up postgres -d",
        "db:down": "docker compose down",
        "db:migrate": "NODE_OPTIONS='--experimental-require-module' prisma db push --schema=libs/data-access/prisma/schema.prisma",
        "db:generate": "NODE_OPTIONS='--experimental-require-module' prisma generate --schema=libs/data-access/prisma/schema.prisma",
        "db:seed": "tsx libs/data-access/prisma/seed.ts",
        "db:studio": "NODE_OPTIONS='--experimental-require-module' prisma studio --config=prisma.config.ts",
        "db:rebuild": "npm run db:down && npm run db:up && npm run db:migrate && npm run db:seed",
        "docker:up": "docker compose up",
        "docker:down": "docker compose down",
        "docker:build": "docker compose build"
    },
    "keywords": [],
    "author": "",
